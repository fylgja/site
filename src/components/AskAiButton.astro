---
import { Bot, Copy, FileCode, MessageSquareCode, ChevronDown } from "@lucide/astro";

interface Props {
	url: string;
	iconSize?: number;
	class?: string;
}

const { url, iconSize = 16, class: classlist } = Astro.props;

const prompt = `Can you explain this documentation page from the Fylgja CSS library? Here is the raw markdown content: ${url}\n\nFor additional context on how Fylgja works, refer to this LLM guide: https://fylgja.dev/llm.txt`;
const claudeUrl = `https://claude.ai/new?q=${encodeURIComponent(prompt)}`;
---

<details class:list={["ask-ai-dropdown relative inline-block", classlist]}>
	<summary class="ask-ai-btn btn list-none" aria-label="Ask AI about this page">
		<Bot class="flex-none" width={iconSize} height={iconSize} aria-hidden="true" />
		<span>Ask AI</span>
		<ChevronDown class="flex-none toggle-flip" width={iconSize} height={iconSize} aria-hidden="true"/>
	</summary>
	<div class="ask-ai-menu card absolute flex flex-col">
		<a
			href={url}
			aria-label="View the current page as Markdown"
			target="_blank"
			rel="noopener noreferrer"
			class="ask-ai-action btn w-full"
		>
			<FileCode class="flex-none" width={iconSize} height={iconSize} aria-hidden="true" />{" "}
			<span>View as Markdown</span>
		</a>
		<button
			type="button"
			class="ask-ai-action copy-action btn w-full"
			data-prompt={prompt}
		>
			<Copy class="flex-none" width={iconSize} height={iconSize} aria-hidden="true" />
			<span class="btn-text">Copy Prompt</span>
		</button>
		<a
			href={claudeUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="ask-ai-action btn w-full"
		>
			<MessageSquareCode class="flex-none" width={iconSize} height={iconSize} aria-hidden="true" />
			<span>Ask Claude</span>
		</a>
	</div>
</details>

<script>
	const copyButtons = document.querySelectorAll<HTMLButtonElement>(".ask-ai-dropdown .copy-action");

	copyButtons.forEach((button) => {
		button.addEventListener("click", async () => {
			const prompt = button.getAttribute("data-prompt");
			if (!prompt) return;

			try {
				await navigator.clipboard.writeText(prompt);

				const textSpan = button.querySelector(".btn-text");
				if (textSpan) {
					const originalText = textSpan.textContent;
					textSpan.textContent = "Copied!";
					setTimeout(() => {
						textSpan.textContent = originalText;
					}, 2000);
				}
			} catch (err) {
				console.error("Failed to copy text: ", err);
			}
		});
	});

	// Close dropdown when clicking outside
	document.addEventListener("click", (event) => {
		const target = event.target as Element;
		if (!target.closest(".ask-ai-dropdown")) {
			document.querySelectorAll(".ask-ai-dropdown[open]").forEach((details) => {
				details.removeAttribute("open");
			});
		}
	});
</script>

<style>
	.ask-ai-menu {
		--card-py: 0.25rem;
		--card-px: 0.25rem;
		--btn-stroke: transparent;
		--btn-radius: 0.75rem;
		top: calc(100% + 0.25rem);
		right: 0;
		z-index: var(--layer-3);
		min-width: 220px;
		box-shadow: var(--shadow-3);
	}

	.ask-ai-btn {
		--btn-py: 0.125rem;
		--btn-px: 0.375rem;
		--btn-stroke: light-dark(currentcolor, color-mix(in srgb, var(--root-fg), transparent 80%));
		color: light-dark(var(--brand), var(--text-color-muted));
		border-width: 1px;
	}

	.ask-ai-action {
		justify-content: flex-start;
		gap: 0.5rem;
	}
</style>
