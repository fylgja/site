---
import { ChevronDown } from "@lucide/astro";
import Schema from "@/components/Schema.astro";

interface Props {
	faq?: {
		question: string;
		answer: string;
	}[];
	listOnly?: boolean;
}

const { faq = [], listOnly = false } = Astro.props;

// Frontmatter answers are plain text (no markdown). Turn `[text](url)` sugar and
// bare https:// URLs into links; everything else stays literal text (so `<dialog>`,
// `[aria-current=page]`, etc. are not treated as markup).
type AnswerPart = { value?: string; href?: string; text?: string; external?: boolean };

function parseAnswer(text: string): AnswerPart[] {
	const parts: AnswerPart[] = [];
	const re = /\[([^\]]+)\]\(([^)\s]+)\)|(https?:\/\/[^\s]+)/g;
	let last = 0;
	let m: RegExpExecArray | null;
	while ((m = re.exec(text)) !== null) {
		if (m.index > last) parts.push({ value: text.slice(last, m.index) });
		if (m[1] !== undefined) {
			const href = m[2];
			parts.push({ href, text: m[1], external: /^(https?:)?\/\//.test(href) });
		} else {
			let url = m[3];
			const trail = url.match(/[.,;:!?)\]]+$/);
			const trailing = trail ? trail[0] : "";
			if (trailing) url = url.slice(0, url.length - trailing.length);
			parts.push({ href: url, text: url, external: true });
			if (trailing) parts.push({ value: trailing });
		}
		last = re.lastIndex;
	}
	if (last < text.length) parts.push({ value: text.slice(last) });
	return parts;
}

// Strip the link sugar to plain text for the JSON-LD, which wants readable prose.
const plainAnswer = (text: string) => text.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, "$1");

const schema = faq.length
	? {
			"@context": "https://schema.org",
			"@type": "FAQPage",
			mainEntity: faq.map(({ question, answer }) => ({
				"@type": "Question",
				name: question,
				acceptedAnswer: {
					"@type": "Answer",
					text: plainAnswer(answer),
				},
			})),
		}
	: null;
---

{
	faq.length > 0 && listOnly && (
		<div class="faq divide-y">
			{faq.map(({ question, answer }, index) => (
				<details name="faq" open={index === 0} class="flow-none">
					<summary class="list-none flex align italic">
						<span>{question}</span>
						<ChevronDown class="toggle-rotate transition" size={20} />
					</summary>
					<p class="faq-content">
						{parseAnswer(answer).map((part) =>
							part.href ? (
								<a
									href={part.href}
									{...(part.external
										? { target: "_blank", rel: "noopener noreferrer" }
										: {})}
								>
									{part.text}
								</a>
							) : (
								part.value
							)
						)}
					</p>
				</details>
			))}
		</div>
	)
}

{
	faq.length > 0 && !listOnly && (
		<section class="faq card" aria-labelledby="faq">
			<h2 id="faq">FAQ</h2>
			<div class="divide-y">
				{faq.map(({ question, answer }, index) => (
					<details name="faq" open={index === 0} class="flow-none">
						<summary class="list-none flex align italic">
							<span>{question}</span>
							<ChevronDown class="toggle-rotate transition" size={20} />
						</summary>
						<p class="faq-content">
							{parseAnswer(answer).map((part) =>
								part.href ? (
									<a
										href={part.href}
										{...(part.external
											? { target: "_blank", rel: "noopener noreferrer" }
											: {})}
									>
										{part.text}
									</a>
								) : (
									part.value
								)
							)}
						</p>
					</details>
				))}
			</div>
		</section>
	)
}

<style>
	.faq {
		--border-color: color-mix(in oklab, var(--root-bg) 75%, var(--root-fg));
		margin-block: var(--size-6);
		border-color: var(--border-color);

		.divide-y {
			border-color: var(--border-color);
		}

		&.card {
			margin-block: var(--size-12);
		}

		summary {
			padding-block: var(--size-3);

			svg {
				flex-shrink: 0;
			}
		}

		.faq-content {
			padding-block: 0 var(--size-3);
		}
	}
</style>

{schema && <Schema data={schema} />}
