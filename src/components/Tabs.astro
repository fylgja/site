---
interface Props {
	class?: string;
	style?: string;
	persist?: boolean | string;
	sync?: boolean;
}

const { class: classes, style, ...rest } = Astro.props;
---

<tab-list class:list={["block", classes]} style={style} {...rest}>
	<div role="tablist" class="flex gap-sm scroll-x">
		<slot name="tablist" />
	</div>
	<slot />
</tab-list>

<style>
	div[role="tablist"] {
		border-block-end: 1px solid var(--border-color-fade);
		padding-block-end: 0;
	}

	tab-list :global([role="tab"]) {
		--outline-offset: -2px;
		--btn-radius: 0.25em;
		padding: 0.4em 0.8em;
		background: none;
		border: 1px solid transparent;
		border-end-start-radius: 0;
		border-end-end-radius: 0;
		color: inherit;
		text-transform: uppercase;
		font-size: 0.875em;
	}

	tab-list :global([role="tab"]:hover) {
		background: color-mix(in srgb, var(--brand) 20%, #fff2);
	}

	tab-list :global([role="tab"][aria-selected="true"]) {
		box-shadow: inset 0 -2px 0 var(--brand);
		border-block-end-color: var(--brand);
	}

</style>

<script>
	// @ts-nocheck
	class TabList extends HTMLElement {
		#buttons = [];
		#panels = [];

		connectedCallback() {
			this.#buttons = [...this.querySelectorAll('[role="tab"]')];
			this.#panels = [...this.querySelectorAll('[role="tabpanel"]')];

			if (!this.#buttons.length || !this.#panels.length) return;

			const active = this.#getPersistedButton() ?? this.#buttons[0];

			this.#buttons.forEach((btn) => {
				const panelId = btn.getAttribute("aria-controls");
				if (!btn.id) btn.id = `${panelId}-btn`;
				btn.setAttribute("aria-selected", btn === active ? "true" : "false");
				btn.setAttribute("tabindex", btn === active ? "0" : "-1");
				btn.addEventListener("click", () => this.#activate(btn));
				btn.addEventListener("keydown", (e) => this.#onKeydown(e));
			});

			this.#panels.forEach((panel) => {
				if (!panel.getAttribute("aria-labelledby")) {
					panel.setAttribute("aria-labelledby", `${panel.id}-btn`);
				}
				panel.hidden = panel.id !== active.getAttribute("aria-controls");
				panel.setAttribute("tabindex", "0");
			});
		}

		#activate(btn, setFocus = true, viaSync = false) {
			if (!viaSync) this.#sync(btn);

			this.#buttons.forEach((b) => {
				b.setAttribute("aria-selected", b === btn ? "true" : "false");
				b.setAttribute("tabindex", b === btn ? "0" : "-1");
			});

			const panelId = btn.getAttribute("aria-controls");
			this.#panels.forEach((p) => {
				p.hidden = p.id !== panelId;
			});

			this.#persist(btn);
			if (setFocus) btn.focus();
		}

		#onKeydown(e) {
			const map = { ArrowLeft: -1, ArrowUp: -1, ArrowRight: 1, ArrowDown: 1 };
			if (e.key === "Home") {
				e.preventDefault();
				this.#activate(this.#buttons[0]);
			} else if (e.key === "End") {
				e.preventDefault();
				this.#activate(this.#buttons[this.#buttons.length - 1]);
			} else if (map[e.key] !== undefined) {
				const idx = this.#buttons.indexOf(e.currentTarget);
				const next = this.#buttons[(idx + map[e.key] + this.#buttons.length) % this.#buttons.length];
				this.#activate(next);
			}
		}

		get #storage() {
			const val = this.getAttribute("persist");
			if (val === "session") return sessionStorage;
			if (this.hasAttribute("persist")) return localStorage;
			return null;
		}

		#persist(btn) {
			const storage = this.#storage;
			if (!storage) return;
			const raw = btn.getAttribute("data-tabs-persist");
			if (!raw) return;
			const [group, value] = raw.split(":");
			if (!group || !value) return;
			const data = JSON.parse(storage.getItem("tabs-persist") ?? "{}");
			data[group] = value;
			storage.setItem("tabs-persist", JSON.stringify(data));
		}

		#getPersistedButton() {
			const storage = this.#storage;
			if (!storage) return null;
			const data = JSON.parse(storage.getItem("tabs-persist") ?? "{}");
			return (
				this.#buttons.find((btn) => {
					const raw = btn.getAttribute("data-tabs-persist");
					if (!raw) return false;
					const [group, value] = raw.split(":");
					return data[group] === value;
				}) ?? null
			);
		}

		#sync(activatedBtn) {
			if (!this.hasAttribute("sync")) return;
			const key = activatedBtn.getAttribute("data-tabs-persist");
			if (!key) return;
			document.querySelectorAll(`[data-tabs-persist="${key}"]`).forEach((btn) => {
				if (btn === activatedBtn) return;
				const group = btn.closest("tab-list[sync]:defined");
				if (group) group.#activate(btn, false, true);
			});
		}
	}

	customElements.define("tab-list", TabList);
</script>
