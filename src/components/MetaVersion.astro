---
import GitIcon from "@/assets/icons/github.svg";
import { ScrollText, Package } from "@lucide/astro";
import AskAiButton from "./AskAiButton.astro";

interface Props {
	version?: string;
	git?: string;
	npm?: string;
	changelog?: string;
	pathUrl?: string;
	iconSize?: number;
}

const { version, git, npm, changelog, pathUrl, iconSize = 16 } = Astro.props;
const npmUrl = npm ? `https://npmjs.com/package/${npm}` : "";
const gitRaw = "https://raw.githubusercontent.com/fylgja/site/refs/heads/main/";
const changelogUrl =
	changelog || git
		? git?.includes("/tree/main")
			? `${git}/CHANGELOG.md`
			: `${git}/tree/main/CHANGELOG.md`
		: "";
---

<div class="meta flex gap-sm align">
	<div class="flex-wrap gap-sm">
		{version && <span>v{version}</span>}
		{
			git && (
				<a href={git} target="_blank" rel="noopener noreferrer" class="meta-link">
					<GitIcon width={iconSize} height={iconSize} aria-hidden="true" />{" "}
					<span>GitHub</span>
				</a>
			)
		}
		{
			npm && (
				<a href={npmUrl} target="_blank" rel="noopener noreferrer" class="meta-link">
					<Package width={iconSize} height={iconSize} aria-hidden="true" /> <span>npm</span>
				</a>
			)
		}
		{
			changelogUrl && (
				<a href={changelogUrl} target="_blank" rel="noopener noreferrer" class="meta-link">
					<ScrollText width={iconSize} height={iconSize} aria-hidden="true" />{" "}
					<span>Changelog</span>
				</a>
			)
		}
	</div>
	{
		pathUrl && (
			<AskAiButton url={gitRaw + pathUrl} iconSize={iconSize} class="flex-none" />
		)
	}
</div>

<style>
	.meta {
		font-size: 0.875em;
		color: var(--text-color-muted);
		border-block-end: 2px solid light-dark(var(--border-color-fade), var(--brand));
		padding-block-end: 0.5em;
	}

	.meta-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		text-decoration: none;
		color: light-dark(var(--brand), var(--text-color-muted));
		background: none;
		border: none;
		padding: 0;
		font-weight: 500;
		cursor: pointer;

		&:hover {
			color: var(--text-color);
		}
	}
</style>
